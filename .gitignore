# ========================================
# Whitelist-based .gitignore for LazyBug
# Only the directories and files explicitly listed below are tracked.
# Everything else is ignored.
# ========================================

# ---- Step 1: Ignore everything by default ----
*

# ---- Step 2: Essential git files ----
!.gitignore
!.gitattributes

# ---- Step 3: Whitelisted root files ----
!LazyBugPlugIn.sln
!ReadMe.md
!VsSDK.props
!LICENSE

# ---- Step 4: Whitelisted directories (recursive) ----
!Common/
!Common/**
!LazyBugPlugIn/
!LazyBugPlugIn/**
!LazyBugPlugInControls/
!LazyBugPlugInControls/**
!LazyBugPlugInCSharp/
!LazyBugPlugInCSharp/**
!LazyBugPlugInLoader/
!LazyBugPlugInLoader/**
!LazyBugPlugInUi/
!LazyBugPlugInUi/**
!LazyBugSource/
!LazyBugSource/**
!Lib_TreeSitterParsers/
!Lib_TreeSitterParsers/**
!Proj_LazyBugCppParser/
!Proj_LazyBugCppParser/**
!Proj_LazyBugService/
!Proj_LazyBugService/**
!doc/
!doc/**
!media/
!media/**

# ---- Step 5: extlib - only first-level empty dirs ----
!extlib/
!extlib/*/
!extlib/*/.gitkeep

# ---- Step 6: Re-ignore build artifacts & generated files within whitelisted dirs ----
**/[Dd]ebug/
**/[Rr]elease/
**/[Bb]in/
**/[Oo]bj/
**/.vs/
**/node_modules/
**/packages/
**/x64/
**/x86/
**/ipch/
**/__pycache__/
**/[Tt]est[Rr]esult*/

# User & generated files
*.user
*.suo
*.rsuser
*.userosscache
*.sln.docstates
*.userprefs
*.vspscc
*.vssscc
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.ilk
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.obj
*.iobj
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.binlog
*.sbr
*.rsp
*.meta
*.pidb
*.svclog
*.scc
*.psess
*.vsp
*.vspx
*.sap
*.e2e
*.gpState
*.dotCover
*.coverage
*.coveragexml
*.nupkg
*.snupkg
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
*.GhostDoc.xml
*.plg
*.opt
*.vbw
*.tss
*.jmconfig
*.btp.cs
*.btm.cs
