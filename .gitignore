*.xsd.cs
*.mm.*
*.nvuser
*.rptproj.bak
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser
*.pyc

# Temporary & backup
~$*
*~
*.[Cc]ache
[Bb]ackup*/
_UpgradeReport_Files/
MigrationBackup/
.localhistory/
