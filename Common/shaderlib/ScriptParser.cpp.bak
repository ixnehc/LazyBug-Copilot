//Code-->Operator Convertor table
int g_CodeOperatorMapTable[]=
{
	O_COMMA,//C_Comma,//","
	O_LEFT_BRACE,//C_LCurve,//"("
	O_RIGHT_BRACE,//C_RCurve,//")"
	O_BITWISE_NOT,//C_Tilde,//"~"
	O_LOGIC_NOT,//C_Excla,//"!"
	O_SUBTRACT,//C_Neg,//"-"
	O_ADD,//C_Pos,//"+"
	O_BITWISE_AND,//C_And,//"&"
	O_MULTIPLY,//C_Asterisk,//"*"
	O_DIVIDE,//C_Slant,//"/"
	O_REMAINDER,//C_Per,//"%"
	O_BITWISE_XOR,//C_Caret,//"^"
	O_BITWISE_OR,//C_Or,//"|"
	O_ASSIGN,//C_Equ,//"="
	O_LESS_THAN,//C_LT,//"<"
	O_GREATER_THAN,//C_GT,//">"
};


