FeatureCode FeatureFromName(const char *name)
{
	int idx=0;

	for(int i=0;i<ARRAY_SIZE(g_FeatureNames);i++)
	{
		if (strcmp(g_FeatureNames[i].name,name)==0)
			return g_FeatureNames[i].fc;
	}
	return FC_none;
}

BOOL FeatureCode::FromName(const char *name)
{
	Clear();
	std::vector<std::string>vecTemp;
	SplitStringBy(",",std::string(name),&vecTemp);

	BOOL bRet=TRUE;
	for (int i=0;i<vecTemp.size();i++)
	{
		FeatureCode fc=FeatureFromName(vecTemp[i].c_str());
		if (fc==FC_none)
			bRet=FALSE;	

		c|=fc.c;
	}

	return bRet;
}

const char *FeatureCode::ToName()
{
	static std::string s;
	s="";

	int idx=0;
	BOOL bFirst=TRUE;
	for(int i=0;i<ARRAY_SIZE(g_FeatureNames);i++)
	{
		if (Test(g_FeatureNames[i].fc))
		{
			if (bFirst)
			{
				s=g_FeatureNames[i].name;
				bFirst=FALSE;
			}
			else
				s=s+","+g_FeatureNames[i].name;
		}
	}

	return s.c_str();
}



BOOL FeatureCode::CheckValidName(const char *name,std::string *firsterrname)
{
	std::vector<std::string>vecTemp;
	SplitStringBy(",",std::string(name),&vecTemp);

	for (int i=0;i<vecTemp.size();i++)
	{
		if (FC_none==FeatureFromName(vecTemp[i].c_str()))
		{
			if (firsterrname)
				(*firsterrname)=vecTemp[i];
			return FALSE;
		}
	}

	return TRUE;
}

//copy from iMath.h
static __forceinline unsigned int fastlog2( unsigned int x)
{
	unsigned int slRet;
	__asm {
		bsr   eax,dword ptr [x]
		mov   dword ptr [slRet],eax
	}
	return slRet;
}

static __forceinline bool ispower2( unsigned int x)
{
	unsigned int p=::fastlog2(x);
	return ((1<<p)==x);
}


//check whether this fc is conflicting based on the fcConflictGroup
BOOL FeatureCode::JudgeConflict(FeatureCode &fcConflictGroup)
{
	unsigned __int64 t;
	t=fcConflictGroup.c&c;

	DWORD l,h;
	l=(DWORD)t;
	h=(DWORD)(t>>32);

	BOOL b1,b2;
	b1=::ispower2(l);
	b2=::ispower2(h);

	if ((l!=0)&&(!b1))
		return TRUE;

	if ((h!=0)&&(!b2))
		return TRUE;

	if ((l!=0)&&(h!=0)&&b1&&b2)//high&low both have 1 bit
		return TRUE;

	return FALSE;
}

int GetNextBit(unsigned __int64 v,int i)
{
	i++;
	while(i<64)
	{
		if (v&(((unsigned __int64)1)<<i))
			return i;
		i++;
	}
	return -1;
}


BOOL FeatureCode::IncWithMask(FeatureCode &fcMask)
{
	unsigned __int64 cBack=c;
	int iBit;
	iBit=GetNextBit(fcMask.c,-1);

	unsigned __int64 bit;

	while(iBit!=-1)
	{
		bit=((unsigned __int64)1)<<iBit;
		if (!(c&bit))
		{
			c|=bit;
			return TRUE;
		}
		else
		{
			c&=(~bit);
			iBit=GetNextBit(fcMask.c,iBit);
		}
	}

	c=cBack;
	return FALSE;
}


//////////////////////////////////////////////////////////////////////////
//ShaderCap
//NOTE:Should be synchronized with SCC_xxxx
const char *g_SCCNames[]=
{
	"maxbones",
	"weightcount",

	//XXXXX:more ShaderCap
	""
};
BOOL ShaderCap::SetCode(const char *sCode)
{
	int idx=0;
	while(1)
	{
		if (g_SCCNames[idx][0]==0)
			break;
		if (strcmp(g_SCCNames[idx],sCode)==0)
		{
			code=(ShaderCapCode)idx;
			return TRUE;
		}
		idx++;
	}
	code=SCC_none;

	return FALSE;
}


BOOL ParseHLSLErrLine(const char *err0,int &nLine)
{
	nLine=-1;
	char *p;
	p=(char *)err0;

	if (*p!='(')
		return FALSE;

	p++;
	std::string sLine;
	while(1)
	{
		if (*p==0)
			return FALSE;
		if (*p==')')
			break;
		sLine+=*p;
		p++;
	}


	nLine=IntFromString(sLine.c_str());

	return TRUE;
}

BOOL ParseCgErrLine(const char *err0,int &nLine)
{
	nLine=-1;
	char *p;
	p=(char *)err0;
	if (strlen(p)<=strlen("ERROR: 0:"))
		return FALSE;
	p+=strlen("ERROR: 0:");
	std::string sLine;
	while(1)
	{
		if (*p==0)
			return FALSE;
		if (*p==':')
			break;
		sLine+=*p;
		p++;
	}

	nLine=IntFromString(sLine.c_str());

	return TRUE;
}
