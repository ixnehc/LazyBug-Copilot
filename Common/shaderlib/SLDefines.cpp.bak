DWORD SizeOfEPInfo()
{
	return ARRAY_SIZE(g_EPInfo);
}

EffectParam EPfromName(const char *name)
{
	for (int i=0;i<SizeOfEPInfo();i++)
	{
		if (strcmp(g_EPInfo[i].name,name)==0)
			return g_EPInfo[i].ep;
	}
	return EP_None;
}


int EPInfo_IndexFromEP(EffectParam ep)
{
	return (int)ep;
}

const char *EPInfo_GetEPName(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return "";
	return g_EPInfo[idx].epname;
}


const char *EPInfo_GetName(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return "";
	return g_EPInfo[idx].name;
}

const char *EPInfo_GetShowName(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return "";
	return g_EPInfo[idx].showname;
}

const char *EPInfo_GetDesc(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return "";
	return g_EPInfo[idx].desc;
}

EffectParam EPInfo_GetEP(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return EP_None;
	return g_EPInfo[idx].ep;
}

int EPInfo_GetArraySize(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return -1;
	return g_EPInfo[idx].arraysize;
}

GVarType EPInfo_GetVarType(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return GVT_None;
	return g_EPInfo[idx].vartype;
}

GSem &EPInfo_GetVarSem(DWORD idx)
{
	static GSem unknown=GSem_Unknown;
	if (idx>=SizeOfEPInfo())
		return unknown;
	return g_EPInfo[idx].varsem;
}

DWORD EPInfo_GetFlag(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return 0;
	return g_EPInfo[idx].flag;
}

KeyType EPInfo_GetKT(DWORD idx)
{
	if (idx>=SizeOfEPInfo())
		return KT_None;
	return g_EPInfo[idx].kt;
}

BYTE *EPInfo_GetDefData(DWORD idx,DWORD &szData)
{
	return g_EPInfo[idx].def.GetData(szData);
}


//////////////////////////////////////////////////////////////////////////
//Feature Flag
//note:should be synchronized with FF_xxxx
const char *g_FeatureFlagNames[]=
{
	"Base",
	"MtrlEdit",
	"MtrlRepair",

	"",
};

FeatureFlag FeatureFlagFromName(const char * name)
{
	int idx=0;
	while(1)
	{
		if (g_FeatureFlagNames[idx][0]==0)
			break;
		if (strcmp(g_FeatureFlagNames[idx],name)==0)
			return (FeatureFlag)(1<<idx);
		idx++;
	}
	return FF_None;
}

