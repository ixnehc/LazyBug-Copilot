//////////////////////////////////////////////////////////////////////////
//ExprCode
void ExprCode::Save(CDataPacket &dp)
{
	dp.Data_NextInt()=type;
	switch(type)
	{
		case Operator:
			dp.Data_NextInt()=op;
			break;
		case Operand_Var:
			dp.Data_WriteString(varname);
			break;
		case Operand_Number:
			dp.Data_NextInt()=varvalue;
			break;
		case Node:
			if (node)
			{
				dp.Data_NextInt()=1;
				node->Save(dp);
			}
			else
				dp.Data_NextInt()=0;
			break;
	}
}

void ExprCode::Load(CDataPacket &dp)
{
	type=(Type)dp.Data_NextInt();
	switch(type)
	{
	case Operator:
		op=dp.Data_NextInt();
		break;
	case Operand_Var:
		dp.Data_ReadString(varname);
		break;
	case Operand_Number:
		varvalue=dp.Data_NextInt();
		break;
	case Node:
		{
			if (dp.Data_NextInt())
			{
				node=new ExprNode;
				node->Load(dp);
			}
			break;
		}
	}
}


//////////////////////////////////////////////////////////////////////////
//ExprNode
void ExprNode::Save(CDataPacket &dp)
{
	ExprCode::Save(dp);

	if (left)
	{
		dp.Data_NextInt()=1;
		left->Save(dp);
	}
	else
		dp.Data_NextInt()=0;

	if (right)
	{
		dp.Data_NextInt()=1;
		right->Save(dp);
	}
	else
		dp.Data_NextInt()=0;

}

void ExprNode::Load(CDataPacket &dp)
{
	ExprCode::Load(dp);
	if (dp.Data_NextInt())
	{
		left=new ExprNode;
		left->Load(dp);
	}
	if (dp.Data_NextInt())
	{
		right=new ExprNode;
		right->Load(dp);
	}

}


void ShaderVar::Save(CDataPacket &dp)
{
	dp.Data_NextInt()=category;
	dp.Data_WriteString(type);
	dp.Data_WriteString(name);
	dp.Data_WriteString(sementic);
	dp.Data_WriteString(annotation);
	dp.Data_WriteString(assign);
	dp.Data_WriteString(statevalue);

	dp.Data_NextInt()=szArray;
	dp.Data_NextInt()=priority;

	if (vInit)
	{
		dp.Data_NextInt()=1;
		vInit->Save(dp);
	}
	else
		dp.Data_NextInt()=0;
}

void ShaderVar::Load(CDataPacket &dp)
{
	Clean();

	category=(ShaderVarCategory)dp.Data_NextInt();
	dp.Data_ReadString(type);
	dp.Data_ReadString(name);
	dp.Data_ReadString(sementic);
	dp.Data_ReadString(annotation);
	dp.Data_ReadString(assign);
	dp.Data_ReadString(statevalue);

	szArray=dp.Data_NextInt();
	priority=dp.Data_NextInt();

	if (dp.Data_NextInt())
	{
		vInit=new ExprNode;
		vInit->Load(dp);
	}
}

