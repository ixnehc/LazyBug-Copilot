//Effect Param info
struct EPInfo
{
	EffectParam ep;
	char *epname;//the name existing in the effect file
	char *name;//standard name
	char *showname;//show name for edit
	char *desc;//description for edit
	GVarType vartype;//if bind to a editable GVar,what the var type should be
	GSem varsem;//if bind to a editable GVar,what the var sementic should be
	DWORD arraysize;//the max array size of this effect param
	DWORD flag;//EPF_XXXX
	KeyType kt;//»зєы’вЄцepњ…“‘ є”√ґѓї≠µƒї∞,÷Єґ®“їЄцKeyType,»зєыќ™KT_None,‘т±н Њ’вЄцep≤їƒ№ є”√ґѓї≠
	GVar def;
};


