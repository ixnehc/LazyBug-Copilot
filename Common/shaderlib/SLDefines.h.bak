class CDataPacket;

//Operator
#define O_NULL					0//for cxi!
#define O_LOGIC_NOT				1//!
#define O_BITWISE_NOT			2//~
#define O_MULTIPLY				3//*
#define O_DIVIDE				4// /
#define	O_REMAINDER				5//%
#define O_ADD					6//+
#define O_SUBTRACT				7//-
#define O_LEFT_SHIFT			8//<<
#define O_RIGHT_SHIFT			9//>>
#define O_LESS_THAN				10//<
#define	O_LESS_THAN_OR_EQUAL	11//<=
#define O_GREATER_THAN			12//>
#define O_GREATER_THAN_OR_EQUAL	13//>=
#define O_EQUAL					14//==
#define	O_NOT_EQUAL				15//!=
#define O_BITWISE_AND			16//&
#define O_BITWISE_XOR			17//^
#define	O_BITWISE_OR			18//|
#define O_LOGIC_AND				19//&&
#define O_LOGIC_OR				20//||
#define O_LEFT_BRACE			21//(
#define O_RIGHT_BRACE			22//)
#define O_ASSIGN				23//=
#define O_NEGATIVE				24//-
#define O_COMMA					25//,
#define O_ARRAY					26//[],replaced by "#"

#define ShaderVarPriority_Default (50)

#define ShaderCapPriority_Default (50)


